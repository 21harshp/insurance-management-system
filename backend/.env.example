# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string_here

# JWT Secret (use a strong random string)
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Server Port
PORT=5001

# Admin Credentials
ADMIN_ID=ADMIN
ADMIN_PASSWORD=your_secure_admin_password_here

# Frontend URL for CORS (set to your Vercel frontend URL in production)
FRONTEND_URL=http://localhost:5173

# Google Drive Integration
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
# Optional for local development: relative path from backend/ to your key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=config/your-service-account-key.json
# For production (Vercel), paste the full JSON content of your service account key file:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...", ...}
